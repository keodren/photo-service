meta {
  name: POST-Image-Store
  type: http
  seq: 1
}

post {
  url: {{endpoint_url}}
  body: json
  auth: inherit
}

body:json {
  { "category_id": 3,
  "user_id": 2,
  "image_url": "https://placeholder.co/600x400",
  "format": "PNG",
  "resolution": "200x200",
  "title": "Example 404",
  "file_size_bytes": 748 }
}

settings {
  encodeUrl: true
  timeout: 0
}
